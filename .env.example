AWS_REGION=eu-west-1
TABLE_NAME=cloudops-incidents-v2
METRICS_TABLE_NAME=cloudops-incident-metrics-v2
DYNAMODB_ENDPOINT=http://dynamodb-local:8000
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
CORS_ORIGINS=http://localhost:8081,http://192.168.0.50:8081,http://mirofish:8081

# Local synthetic-data demo only. Fake mode never calls AWS or a foundation model.
# Keep disabled by default and do not configure a real Bedrock model in this change.
AI_SUMMARY_ENABLED=false
AI_SUMMARY_PROVIDER=disabled
AI_SUMMARY_MODEL_ID=fake-local-model
AI_SUMMARY_PROMPT_VERSION=incident-summary-v1
AI_SUMMARY_MAX_CONTEXT_CHARS=8000
AI_SUMMARY_MAX_OUTPUT_CHARS=6000
