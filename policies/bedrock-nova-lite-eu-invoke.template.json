{
  "metadata": {
    "directive": "DO_NOT_APPLY",
    "human_review_required": true,
    "status": "disabled"
  },
  "policy_template": {
    "Statement": [
      {
        "Action": "bedrock:InvokeModel",
        "Effect": "Allow",
        "Resource": "arn:${AWS_PARTITION}:bedrock:${SOURCE_REGION}:${AWS_ACCOUNT_ID}:inference-profile/eu.amazon.nova-lite-v1:0",
        "Sid": "InvokeApprovedEuInferenceProfile"
      },
      {
        "Action": "bedrock:InvokeModel",
        "Condition": {
          "StringEquals": {
            "bedrock:InferenceProfileArn": "arn:${AWS_PARTITION}:bedrock:${SOURCE_REGION}:${AWS_ACCOUNT_ID}:inference-profile/eu.amazon.nova-lite-v1:0"
          }
        },
        "Effect": "Allow",
        "Resource": [
          "arn:${AWS_PARTITION}:bedrock:eu-central-1::foundation-model/amazon.nova-lite-v1:0",
          "arn:${AWS_PARTITION}:bedrock:eu-north-1::foundation-model/amazon.nova-lite-v1:0",
          "arn:${AWS_PARTITION}:bedrock:eu-west-1::foundation-model/amazon.nova-lite-v1:0",
          "arn:${AWS_PARTITION}:bedrock:eu-west-3::foundation-model/amazon.nova-lite-v1:0"
        ],
        "Sid": "InvokeNovaLiteOnlyThroughApprovedProfile"
      }
    ],
    "Version": "2012-10-17"
  }
}
